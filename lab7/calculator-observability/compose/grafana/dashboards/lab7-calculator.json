{
  "title": "Calculator Backend",
  "uid": "calculator-backend",
  "tags": ["lab7", "calculator"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_requests_total{job=\"calculator-backend\"}[1m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Duration p99 (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"calculator-backend\"}[1m]))",
          "legendFormat": "p99 {{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Calculations (бизнес-метрика)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(calculator_operations_total{job=\"calculator-backend\"})",
          "legendFormat": "Всего операций"
        }
      ]
    },
    {
      "id": 4,
      "title": "Calculations by Operation",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(operation) (calculator_operations_total{job=\"calculator-backend\"})",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_requests_total{job=\"calculator-backend\", status=~\"4..|5..\"}[1m])",
          "legendFormat": "errors {{status}}"
        }
      ]
    }
  ]
}
